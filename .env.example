# ============================================================
# PigeonCloud テストエージェント 環境設定
# このファイルをコピーして .env を作成してください
# .env は絶対にgitにコミットしないこと
# ============================================================

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# テスト対象URL（ステージング）
TEST_BASE_URL=https://staging.pigeoncloud.jp

# テスト専用テナント認証情報
TEST_TENANT_ID=
TEST_EMAIL=claude-test@example.com
TEST_PASSWORD=

# DB接続（テスト専用テナントのDB）
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Slack通知設定
SLACK_WEBHOOK_URL=SLACK_WEBHOOK_PLACEHOLDER
SLACK_NOTIFY_USER_ID=U869KKT8C

# PigeonCloudソースコードのパス（コンテナ内）
PIGEON_SOURCE_PATH=/app/src/pigeon_cloud

# Google Sheets設定
GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/service_account.json
SPREADSHEET_ID=1h_gwuCGUAdj5fKPRZu438TKFkFkYUNUKz2K_vtEFlmI
SHEET_GID=46306531
